{
  "name": "@romanbakurov/vellira",
  "private": true,
  "version": "2.8.0",
  "description": "Vellira Design System monorepo",
  "type": "module",
  "author": "Roman Bakurov",
  "license": "MIT",
  "scripts": {
    "lint": "eslint 'packages/**/*.{ts,tsx}' 'apps/**/*.{ts,tsx}'",
    "lint:fix": "eslint 'packages/**/*.{ts,tsx}' 'apps/**/*.{ts,tsx}' --fix",
    "format": "prettier '**/*.{ts,tsx,json,md,css,scss}' --write",
    "format:check": "prettier '**/*.{ts,tsx,json,md,css,scss}' --check",
    "typecheck": "pnpm -r --if-present typecheck",
    "build": "pnpm build:packages",
    "build:packages": "pnpm build:base && pnpm build:renderers",
    "build:base": "pnpm --filter @romanbakurov/vellira-types build && pnpm --filter @romanbakurov/vellira-core build && pnpm --filter @romanbakurov/vellira-icons build && pnpm --filter @romanbakurov/vellira-tokens build",
    "build:renderers": "pnpm --filter @romanbakurov/vellira-web build && pnpm --filter @romanbakurov/vellira-native build",
    "storybook": "pnpm --filter @vellira/web-storybook dev",
    "native": "pnpm --filter native-playground start",
    "build:storybook": "pnpm --filter @vellira/web-storybook build",
    "build:native-playground": "pnpm --filter native-playground exec expo export --platform ios --platform android --output-dir dist",
    "test": "pnpm test:unit && pnpm test:storybook && pnpm test:e2e:web",
    "test:unit": "pnpm test:tokens && pnpm test:web && pnpm test:native",
    "test:web": "pnpm --filter @romanbakurov/vellira-web test",
    "test:tokens": "pnpm --filter @romanbakurov/vellira-tokens test",
    "test:native": "pnpm --filter @romanbakurov/vellira-native test",
    "test:storybook": "pnpm --filter @vellira/web-storybook test",
    "test:e2e:web": "pnpm --filter @vellira/web-storybook test:e2e",
    "test:coverage": "pnpm test:coverage:web && pnpm test:coverage:native",
    "test:coverage:web": "pnpm --filter @romanbakurov/vellira-web test:coverage",
    "test:coverage:native": "pnpm --filter @romanbakurov/vellira-native test:coverage",
    "docs:api": "tsx scripts/generate-api-docs.ts",
    "docs:api:check": "tsx scripts/generate-api-docs.ts --check",
    "check:public-api": "node scripts/check-public-api.mjs",
    "create:component": "tsx scripts/generators/create-component.ts",
    "prepare": "husky",
    "smoke:web": "node scripts/smoke/web.mjs --skip-build",
    "smoke:native": "node scripts/smoke/native.mjs --skip-build",
    "smoke:packages": "pnpm build && pnpm smoke:web && pnpm smoke:native",
    "playground:native": "pnpm --filter native-playground start",
    "playground:native:ios": "pnpm --filter native-playground ios",
    "playground:native:android": "pnpm --filter native-playground android",
    "storybook:native": "pnpm --filter native-storybook start",
    "storybook:native:ios": "pnpm --filter native-storybook ios",
    "storybook:native:android": "pnpm --filter native-storybook android"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^9.39.4",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/node": "^24.12.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-postcss-modules": "^2.0.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "semantic-release": "^24.2.9",
    "stylelint": "^17.11.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-scss": "^7.1.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9",
    "typescript-eslint": "^8.61.0"
  },
  "overrides": {
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f"
}
