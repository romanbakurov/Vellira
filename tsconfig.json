{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "lib": ["ES2022", "DOM"],

    "strict": true,

    "jsx": "react-jsx",

    "skipLibCheck": true,
    "declaration": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["types/**/*.d.ts"]
}
