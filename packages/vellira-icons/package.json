{
  "name": "@romanbakurov/vellira-icons",
  "version": "2.7.0",
  "description": "Cross-platform icon package for Vellira Design System",
  "author": "Roman Bakurov",
  "license": "MIT",
  "private": false,
  "type": "module",
  "sideEffects": false,

  "main": "./dist/web.js",
  "module": "./dist/web.js",
  "types": "./dist/web.d.ts",
  "react-native": "./dist/native.js",

  "exports": {
    ".": {
      "types": "./dist/web.d.ts",
      "react-native": "./dist/native.js",
      "import": "./dist/web.js",
      "default": "./dist/web.js"
    },
    "./web": {
      "types": "./dist/web.d.ts",
      "import": "./dist/web.js",
      "default": "./dist/web.js"
    },
    "./native": {
      "types": "./dist/native.d.ts",
      "import": "./dist/native.js",
      "default": "./dist/native.js"
    }
  },

  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],

  "scripts": {
    "clean": "node --input-type=module -e \"import fs from 'node:fs'; fs.rmSync('dist', { recursive: true, force: true }); fs.rmSync('src/generated', { recursive: true, force: true })\"",
    "generate": "tsx scripts/generate-icons.ts && pnpm --workspace-root exec prettier 'packages/vellira-icons/src/**/*.{ts,tsx}' --write",
    "build": "pnpm run clean && pnpm run generate && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },

  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.72",
    "react-native-svg": ">=13"
  },

  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    },
    "react-native-svg": {
      "optional": true
    }
  },

  "devDependencies": {
    "@svgr/core": "^8.1.0",
    "@svgr/plugin-jsx": "^8.1.0",
    "@types/react": "^19.2.17",
    "fast-glob": "^3.3.3"
  },

  "publishConfig": {
    "access": "public"
  }
}