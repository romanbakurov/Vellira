{
  "name": "@romanbakurov/flux-ui-icons",
  "version": "0.0.1",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "main": "./src/web.ts",
  "exports": {
    ".": {
      "react-native": "./src/native.ts",
      "import": "./src/web.ts",
      "default": "./src/web.ts"
    }
  },
  "scripts": {
    "clean": "rm -rf src/generated/*.jsx",
    "generate": "pnpm clean && tsx scripts/generate-icons.ts && pnpm --workspace-root exec prettier 'packages/flux-ui-icons/src/**/*.{ts,jsx}' --write",
    "build": "pnpm generate"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": "*",
    "react-native-svg": "*"
  },
  "devDependencies": {
    "tsx": "^4",
    "fast-glob": "^3.3.3",
    "@svgr/core": "^8.1.0",
    "@svgr/plugin-jsx": "^8.1.0",
    "typescript": "^6"
  }
}
