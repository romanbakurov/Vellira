{
  "name": "@romanbakurov/vellira-web",
  "version": "2.7.0",
  "description": "Web components for Vellira Design System",
  "author": "Roman Bakurov",
  "license": "MIT",
  "private": false,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "node --input-type=module -e \"import fs from 'node:fs'; fs.rmSync('dist', { recursive: true, force: true })\"",
    "build": "pnpm run clean && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "react": ">=18.2 <20",
    "react-dom": ">=18.2 <20"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.19",
    "@romanbakurov/vellira-core": "workspace:*",
    "@romanbakurov/vellira-icons": "workspace:*",
    "@romanbakurov/vellira-tokens": "workspace:*",
    "@romanbakurov/vellira-types": "workspace:*",
    "clsx": "^2.1.1",
    "focus-trap-react": "^12.0.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^28.1.0",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.0",
    "vite-plugin-lib-inject-css": "^2.2.2",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^4.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
