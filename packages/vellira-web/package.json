{
  "name": "@romanbakurov/vellira-web",
  "version": "2.7.0",
  "license": "MIT",
  "private": false,
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js"
    },
    "./styles": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.19",
    "@romanbakurov/vellira-core": "workspace:*",
    "@romanbakurov/vellira-icons": "workspace:*",
    "@romanbakurov/vellira-tokens": "workspace:*",
    "@romanbakurov/vellira-types": "workspace:*",
    "clsx": "^2.1.1",
    "focus-trap-react": "^12.0.2"
  },
  "peerDependencies": {
    "react": ">=18.2 <20",
    "react-dom": ">=18.2 <20"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^28.1.0",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.0",
    "vite-plugin-lib-inject-css": "^2.2.2",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^4.1.8"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  }
