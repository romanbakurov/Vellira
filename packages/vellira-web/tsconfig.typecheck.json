{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "../..",
    "composite": false,
    "paths": {
      "@/*": ["*"],
      "@romanbakurov/vellira-core": ["../../vellira-core/src/index.ts"],
      "@romanbakurov/vellira-icons": ["../../vellira-icons/src/web.ts"],
      "@romanbakurov/vellira-icons/native": [
        "../../vellira-icons/src/native.ts"
      ],
      "@romanbakurov/vellira-icons/web": ["../../vellira-icons/src/web.ts"],
      "@romanbakurov/vellira-native": ["../../vellira-native/src/index.ts"],
      "@romanbakurov/vellira-tokens": ["../../vellira-tokens/src/index.ts"],
      "@romanbakurov/vellira-types": ["../../vellira-types/src/index.ts"],
      "@romanbakurov/vellira-web": ["index.ts"],
      "@components/*": ["components/*"],
      "@hooks/*": ["hooks/*"],
      "@overlay/*": ["overlay/*"],
      "@patterns/*": ["patterns/*"],
      "@primitives/*": ["primitives/*"],
      "@styles/*": ["styles/*"],
      "@utils/*": ["utils/*"],
      "@assets/*": ["assets/*"]
    }
  }
}
