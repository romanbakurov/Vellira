{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "jsx": "react-jsx",
    "declaration": true,
    "rootDir": "src",
    "outDir": "dist",
    "composite": true,
    "strict": true,
    "moduleResolution": "Bundler",
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": ["src"],
  "exclude": [
    "**/*.stories.*",
    "**/*.test.*",
    "src/test-utils",
    "test",
    "dist",
    "node_modules"
  ]
}
