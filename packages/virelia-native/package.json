{
  "name": "@romanbakurov/virelia-native",
  "version": "2.4.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "react-native": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.stories.*"
  ],
  "scripts": {
    "clean": "node --input-type=module -e \"import fs from 'node:fs'; fs.rmSync('dist', { recursive: true, force: true })\"",
    "build": "pnpm clean && tsc -p tsconfig.json"
  },
  "peerDependencies": {
    "react": "^19.1.0",
    "react-native": ">=0.81"
  },
  "dependencies": {
    "@romanbakurov/virelia-tokens": "workspace:*",
    "@romanbakurov/virelia-types": "workspace:*",
    "@romanbakurov/virelia-core": "workspace:*",
    "@romanbakurov/virelia-icons": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.2.3"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  }
}
